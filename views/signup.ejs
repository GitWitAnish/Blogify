<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Sign Up - Blogify</title>
</head>
<body>
    <%- include('./partials/nav.ejs') %>
    
    <div class="auth-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6">
                    <div class="auth-card">
                        <div class="auth-header">
                            <i class="bi bi-rocket-takeoff" style="font-size: 3rem; margin-bottom: 1rem;"></i>
                            <h2 class="mb-0">Join Blogify</h2>
                            <p class="mb-0 mt-2" style="opacity: 0.9;">Start sharing your stories today</p>
                        </div>
                        <div class="p-4">
                            <% if (locals.error) { %>
                                <div class="alert alert-danger d-flex align-items-center" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <div><%= error %></div>
                                </div>
                            <% } %>
                            <form action="/user/signup" method="POST" enctype="multipart/form-data">
                                <div class="mb-4 text-center">
                                    <label for="profileImage" class="form-label fw-semibold">Profile Picture</label>
                                    <div class="mb-3">
                                        <img id="profilePreview" src="/images/avatar.jpg" alt="Profile Preview" 
                                             class="rounded-circle shadow" width="120" height="120" style="object-fit: cover; border: 4px solid white;">
                                    </div>
                                    <input type="file" 
                                           class="form-control" 
                                           name="profileImage" 
                                           id="profileImage" 
                                           accept="image/*"
                                           onchange="previewImage(event)">
                                    <div class="form-text">JPG, PNG, or GIF (max 5MB)</div>
                                </div>

                                <div class="mb-3">
                                    <label for="name" class="form-label fw-semibold">
                                        <i class="bi bi-person me-2"></i>Full Name
                                    </label>
                                    <input type="text" 
                                           class="form-control form-control-lg" 
                                           name="name" 
                                           id="name" 
                                           placeholder="Anish Karki"
                                           required>
                                </div>

                                <div class="mb-3">
                                    <label for="email" class="form-label fw-semibold">
                                        <i class="bi bi-envelope me-2"></i>Email Address
                                    </label>
                                    <input type="email"
                                           name="email"
                                           class="form-control form-control-lg"
                                           id="email" 
                                           placeholder="you@example.com"
                                           required>
                                </div>

                                <div class="mb-4">
                                    <label for="password" class="form-label fw-semibold">
                                        <i class="bi bi-key me-2"></i>Password
                                    </label>
                                    <input type="password" 
                                           name="password"
                                           class="form-control form-control-lg" 
                                           id="password"
                                           placeholder="Create a strong password"
                                           required>
                                </div>

                                <div class="d-grid mb-3">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="bi bi-check-circle me-2"></i>Create Account
                                    </button>
                                </div>
                            </form>
                            <div class="text-center pt-3 border-top">
                                <p class="text-muted mb-0">
                                    Already have an account? 
                                    <a href="/user/signin" class="fw-semibold text-decoration-none" style="color: var(--primary);">
                                        Sign In
                                    </a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('./partials/scripts.ejs') %>
    
    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('profilePreview');
            
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                };
                reader.readAsDataURL(file);
            } else {
                preview.src = '/images/avatar.jpg';
            }
        }
    </script>
</body>
</html>