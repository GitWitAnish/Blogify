<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Signup</title>
</head>
<body>
    <%- include('./partials/nav.ejs') %>
    
 <div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Sign Up</h3>
                </div>
                <div class="card-body">
                    <% if (locals.error) { %>
                        <div class="alert alert-danger" role="alert">
                            <%= error %>
                        </div>
                    <% } %>
                    <form action="/user/signup" method="POST" enctype="multipart/form-data">
                        <div class="mb-3 text-center">
                            <label for="profileImage" class="form-label">Profile Picture</label>
                            <div class="mb-2">
                                <img id="profilePreview" src="/images/avatar.jpg" alt="Profile Preview" 
                                     class="rounded-circle" width="100" height="100" style="object-fit: cover;">
                            </div>
                            <input type="file" 
                                   class="form-control" 
                                   name="profileImage" 
                                   id="profileImage" 
                                   accept="image/*"
                                   onchange="previewImage(event)">
                            <div class="form-text"> Choose a profile picture (JPG, PNG, GIF)</div>
                        </div>

                        <div class="mb-3">
                            <label for="name" class="form-label">Full Name</label>
                            <input type="text" 
                                   class="form-control" 
                                   name="name" 
                                   id="name" 
                                   required>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email address</label>
                            <input type="email"
                                   name="email"
                                   class="form-control"
                                   id="email" 
                                   required>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" 
                                   name="password"
                                   class="form-control" 
                                   id="password"
                                   required>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Sign Up</button>
                        </div>
                    </form>
                    <div class="text-center mt-3">
                        <p>Already have an account? <a href="/user/signin">Sign In</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>



 </div>
    <%- include('./partials/scripts.ejs') %>
    
    <script>
        function previewImage(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('profilePreview');
            
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                };
                reader.readAsDataURL(file);
            } else {
                preview.src = '/images/avatar.jpg';
            }
        }
    </script>
</body>
</html>