<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Page Not Found - 404</title>
</head>
<body>
    <%- include('./partials/nav.ejs') %>
    
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <div class="error-template">
                    <h1 class="display-1 text-primary">404</h1>
                    <h2 class="mb-3">Oops! Page Not Found</h2>
                    <div class="error-details mb-4">
                        <p class="text-muted">Sorry, the page you are looking for could not be found.</p>
                    </div>
                    <div class="error-actions">
                        <a href="/" class="btn btn-primary btn-lg">
                            <i class="bi bi-house-fill"></i> Go Home
                        </a>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg ms-2">
                            <i class="bi bi-arrow-left"></i> Go Back
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('./partials/scripts.ejs') %>
</body>
</html>
