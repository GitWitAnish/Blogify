<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Blogify - Share Your Stories</title>
</head>
<body>
    <%- include('./partials/nav.ejs') %>
    
    <div class="main-content">
        <div class="container">
            <!-- Hero Section -->
            <div class="hero-section text-center">
                <% if (locals.user) { %>
                    <h1 class="display-3 gradient-text mb-3">
                        Welcome back, <%= user.name %>! ✨
                    </h1>
                    <p class="lead text-muted mb-4">Ready to share your next story with the world?</p>
                    <a href="/blog/add" class="btn btn-primary btn-lg">
                        <i class="bi bi-pencil-square me-2"></i>Create New Blog
                    </a>
                <% } else { %>
                    <h1 class="display-2 gradient-text mb-3">
                        Welcome to Blogify
                    </h1>
                    <p class="lead text-muted mb-4">Discover stories, thinking, and expertise from writers on any topic.</p>
                    <div class="d-flex gap-3 justify-content-center">
                        <a href="/user/signup" class="btn btn-primary btn-lg">
                            <i class="bi bi-rocket-takeoff me-2"></i>Start Writing
                        </a>
                        <a href="/user/signin" class="btn btn-outline-secondary btn-lg">
                            Sign In
                        </a>
                    </div>
                <% } %>
            </div>

            <!-- Blog Posts Section -->
            <div class="row">
                <div class="col-12">
                    <h2 class="section-title mb-4">Latest Stories</h2>
                </div>
            </div>

            <% if (locals.blogs && blogs.length > 0) { %>
                <div class="row g-4">
                    <% blogs.forEach(blog => { %>
                        <div class="col-md-6 col-lg-4">
                            <div class="blog-card" onclick="window.location.href='/blog/<%= blog._id %>'">
                                <div class="cover-wrapper">
                                    <% if (blog.coverImageURL) { %>
                                        <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>">
                                    <% } else { %>
                                        <div class="cover-placeholder">
                                            <i class="bi bi-file-text" style="font-size: 3.5rem; color: white; opacity: .7;"></i>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="card-body">
                                    <div class="author-chip">
                                        <img src="<%= blog.createdBy.profileImageURL || '/images/avatar.jpg' %>" 
                                             alt="<%= blog.createdBy.name %>" 
                                             onerror="this.src='/images/avatar.jpg';">
                                        <span><%= blog.createdBy.name %></span>
                                    </div>
                                    <h5 class="card-title"><%= blog.title %></h5>
                                    <p class="card-text">
                                        <%= blog.body.length > 120 ? blog.body.substring(0, 120) + '...' : blog.body %>
                                    </p>
                                    <div class="card-footer-row">
                                        <small>
                                            <i class="bi bi-calendar3 me-1"></i>
                                            <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                        </small>
                                        <a href="/blog/<%= blog._id %>" class="read-more-link" onclick="event.stopPropagation()">
                                            Read More <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <div class="floating-animation">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h4 class="text-muted mb-2">No stories yet</h4>
                    <p class="text-muted mb-4">Be the first to share your story with the community!</p>
                    <% if (locals.user) { %>
                        <a href="/blog/add" class="btn btn-primary">
                            <i class="bi bi-pencil-square me-2"></i>Write Your First Story
                        </a>
                    <% } else { %>
                        <a href="/user/signin" class="btn btn-primary">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In to Write
                        </a>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>
 
    <%- include('./partials/scripts.ejs') %>
</body>
</html>