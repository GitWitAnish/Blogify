<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title>Homepage</title>
</head>
<body>
    <%- include('./partials/nav.ejs') %>
    
    <div class="container mt-4">
        <div class="row">
            <div class="col-12">
                <% if (locals.user) { %>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="display-4">Welcome back, <%= user.name %>!</h1>
                        <a href="/blog/add" class="btn btn-primary">Create New Blog</a>
                    </div>
                    <p class="lead">You are successfully signed in to the blog.</p>
                <% } else { %>
                    <h1 class="display-4">Welcome to My Blog</h1>
                    <p class="lead">This is a simple blog application built with Express and EJS.</p>
                    <hr class="my-4">
                    <p>Please sign in or create an account:</p>
                    <div class="mt-4 mb-4">
                        <a href="/user/signup" class="btn btn-primary me-2">Sign Up</a>
                        <a href="/user/signin" class="btn btn-outline-primary">Sign In</a>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Blog Posts Section -->
        <div class="row mt-4">
            <div class="col-12">
                <h2 class="mb-4">Latest Blog Posts</h2>
                <% if (locals.blogs && blogs.length > 0) { %>
                    <div class="row">
                        <% blogs.forEach(blog => { %>
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100" style="cursor: pointer; transition: transform 0.2s;" 
                                     onclick="window.location.href='/blog/<%= blog._id %>'"
                                     onmouseover="this.style.transform='scale(1.02)'" 
                                     onmouseout="this.style.transform='scale(1)'">
                                    <% if (blog.coverImageURL) { %>
                                        <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="<%= blog.title %>" style="height: 200px; object-fit: cover;">
                                    <% } %>
                                    <div class="card-body d-flex flex-column">
                                        <h5 class="card-title"><%= blog.title %></h5>
                                        <p class="card-text flex-grow-1">
                                            <%= blog.body.length > 150 ? blog.body.substring(0, 150) + '...' : blog.body %>
                                        </p>
                                        <div class="mt-auto">
                                            <small class="text-muted">
                                                By <%= blog.createdBy.name %> • <%= new Date(blog.createdAt).toLocaleDateString() %>
                                            </small>
                                        </div>
                                        <div class="mt-2">
                                            <a href="/blog/<%= blog._id %>" class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation()">
                                                Read More
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <h4 class="text-muted">No blog posts yet</h4>
                        <p class="text-muted">Be the first to create a blog post!</p>
                        <% if (locals.user) { %>
                            <a href="/blog/add" class="btn btn-primary">Create Your First Blog</a>
                        <% } else { %>
                            <a href="/user/signin" class="btn btn-primary">Sign In to Create Blog</a>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>

        <% if (locals.user) { %>
            <hr class="my-4">
            <div class="text-center">
                <a href="/user/logout" class="btn btn-outline-danger">Logout</a>
            </div>
        <% } %>
    </div>
 
    <%- include('./partials/scripts.ejs') %>
</body>
</html>