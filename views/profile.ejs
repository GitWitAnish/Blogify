<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title><%= profileUser.name %> - Profile | Blogify</title>
    <style>
        .profile-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border-radius: var(--radius);
            padding: 3rem 2rem;
            color: white;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-lg);
        }
        .profile-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 400px;
            height: 400px;
            background: rgba(255,255,255,0.08);
            border-radius: 50%;
        }
        .profile-header::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }
        .profile-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid rgba(255,255,255,0.9);
            box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        }
        .profile-stats {
            display: flex;
            gap: 2rem;
            margin-top: 1.5rem;
        }
        .profile-stat {
            text-align: center;
        }
        .profile-stat-value {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.75rem;
            font-weight: 700;
        }
        .profile-stat-label {
            font-size: 0.85rem;
            opacity: 0.85;
        }
        .profile-section {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-sm);
            padding: 2rem;
            margin-bottom: 1.5rem;
        }
        .profile-section-title {
            font-size: 1.25rem;
            margin-bottom: 1.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid var(--border);
        }
    </style>
</head>
<body>
    <%- include('./partials/nav.ejs') %>

    <div class="main-content">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">

                    <!-- Breadcrumb -->
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/" class="text-decoration-none" style="color: var(--primary);"><i class="bi bi-house-door me-1"></i>Home</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Profile</li>
                        </ol>
                    </nav>

                    <% if (locals.success) { %>
                        <div class="alert alert-success d-flex align-items-center mb-4">
                            <i class="bi bi-check-circle me-2"></i>
                            <span><%= success %></span>
                        </div>
                    <% } %>
                    <% if (locals.error) { %>
                        <div class="alert alert-danger d-flex align-items-center mb-4">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <span><%= error %></span>
                        </div>
                    <% } %>

                    <!-- Profile Header -->
                    <div class="profile-header mb-4">
                        <div class="d-flex flex-column flex-md-row align-items-center gap-4 position-relative" style="z-index: 1;">
                            <img src="<%= profileUser.profileImageURL || '/images/avatar.jpg' %>" 
                                 alt="<%= profileUser.name %>" 
                                 class="profile-avatar"
                                 onerror="this.src='/images/avatar.jpg';">
                            <div class="text-center text-md-start">
                                <h1 class="mb-1" style="font-size: 2rem;"><%= profileUser.name %></h1>
                                <p class="mb-0 opacity-75">
                                    <i class="bi bi-envelope me-1"></i><%= profileUser.email %>
                                </p>
                                <p class="mb-0 opacity-75">
                                    <i class="bi bi-calendar3 me-1"></i>Joined <%= new Date(profileUser.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                </p>
                                <div class="profile-stats">
                                    <div class="profile-stat">
                                        <div class="profile-stat-value"><%= locals.blogs ? blogs.length : 0 %></div>
                                        <div class="profile-stat-label">Stories</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Edit Profile (only for own profile) -->
                        <% if (locals.isOwnProfile && isOwnProfile) { %>
                            <div class="col-lg-5 mb-4 mb-lg-0">
                                <div class="profile-section h-100">
                                    <h3 class="profile-section-title">
                                        <i class="bi bi-gear me-2"></i>Edit Profile
                                    </h3>
                                    <form action="/user/profile/update" method="POST" enctype="multipart/form-data">
                                        <div class="mb-3">
                                            <label for="name" class="form-label fw-semibold">
                                                <i class="bi bi-person me-1"></i>Name
                                            </label>
                                            <input type="text" class="form-control" id="name" name="name" 
                                                   value="<%= profileUser.name %>" required>
                                        </div>
                                        <div class="mb-3">
                                            <label for="email" class="form-label fw-semibold">
                                                <i class="bi bi-envelope me-1"></i>Email
                                            </label>
                                            <input type="email" class="form-control" id="email" 
                                                   value="<%= profileUser.email %>" disabled>
                                            <div class="form-text">Email cannot be changed</div>
                                        </div>
                                        <div class="mb-4">
                                            <label for="profileImage" class="form-label fw-semibold">
                                                <i class="bi bi-camera me-1"></i>Profile Image
                                            </label>
                                            <div class="d-flex align-items-center gap-3 mb-2">
                                                <img src="<%= profileUser.profileImageURL || '/images/avatar.jpg' %>" 
                                                     alt="Current" class="rounded-circle" width="50" height="50" 
                                                     style="object-fit: cover; border: 2px solid var(--border);"
                                                     id="profilePreview"
                                                     onerror="this.src='/images/avatar.jpg';">
                                                <span class="text-muted small">Current photo</span>
                                            </div>
                                            <input type="file" class="form-control" id="profileImage" name="profileImage" 
                                                   accept="image/*" onchange="previewProfileImage(event)">
                                            <div class="form-text">Max 5MB. JPG, PNG, GIF or WebP</div>
                                        </div>
                                        <button type="submit" class="btn btn-primary w-100">
                                            <i class="bi bi-check-circle me-2"></i>Save Changes
                                        </button>
                                    </form>
                                </div>
                            </div>
                        <% } %>

                        <!-- User's Blogs -->
                        <div class="<%= (locals.isOwnProfile && isOwnProfile) ? 'col-lg-7' : 'col-12' %>">
                            <div class="profile-section">
                                <h3 class="profile-section-title">
                                    <i class="bi bi-journal-text me-2"></i><%= (locals.isOwnProfile && isOwnProfile) ? 'Your' : profileUser.name + "'s" %> Stories
                                </h3>

                                <% if (locals.blogs && blogs.length > 0) { %>
                                    <% blogs.forEach(blog => { %>
                                        <div class="d-flex gap-3 mb-3 p-3" style="background: var(--bg); border-radius: var(--radius); cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;" 
                                             onclick="window.location.href='/blog/<%= blog._id %>'"
                                             onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='var(--shadow-md)'"
                                             onmouseout="this.style.transform=''; this.style.boxShadow=''">
                                            <% if (blog.coverImageURL) { %>
                                                <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" 
                                                     class="rounded" style="width: 80px; height: 80px; object-fit: cover; flex-shrink: 0;">
                                            <% } else { %>
                                                <div class="rounded d-flex align-items-center justify-content-center" 
                                                     style="width: 80px; height: 80px; flex-shrink: 0; background: linear-gradient(135deg, var(--primary), var(--secondary));">
                                                    <i class="bi bi-file-text" style="font-size: 1.5rem; color: white;"></i>
                                                </div>
                                            <% } %>
                                            <div class="d-flex flex-column justify-content-center overflow-hidden">
                                                <h6 class="mb-1 text-truncate"><%= blog.title %></h6>
                                                <p class="mb-1 text-muted small text-truncate"><%= blog.body.substring(0, 100) %></p>
                                                <small class="text-muted">
                                                    <i class="bi bi-calendar3 me-1"></i>
                                                    <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                                </small>
                                            </div>
                                        </div>
                                    <% }); %>
                                <% } else { %>
                                    <div class="text-center py-5">
                                        <div class="floating-animation mb-3">
                                            <i class="bi bi-journal-x" style="font-size: 3rem; color: var(--primary-light);"></i>
                                        </div>
                                        <h5 class="text-muted mb-2">No stories yet</h5>
                                        <% if (locals.isOwnProfile && isOwnProfile) { %>
                                            <p class="text-muted mb-3">Start sharing your thoughts with the world!</p>
                                            <a href="/blog/add" class="btn btn-primary">
                                                <i class="bi bi-pencil-square me-2"></i>Write Your First Story
                                            </a>
                                        <% } else { %>
                                            <p class="text-muted"><%= profileUser.name %> hasn't published any stories yet.</p>
                                        <% } %>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <%- include('./partials/scripts.ejs') %>

    <script>
        function previewProfileImage(event) {
            const file = event.target.files[0];
            const preview = document.getElementById('profilePreview');
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                };
                reader.readAsDataURL(file);
            }
        }
    </script>
</body>
</html>
