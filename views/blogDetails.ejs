<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title><% if (locals.blog) { %><%= blog.title %> - Blogify<% } else { %>Blog Details<% } %></title>
</head>
<body>
    <%- include('./partials/nav.ejs') %>
    
    <% if (locals.error) { %>
        <div class="main-content">
            <div class="container">
                <div class="text-center py-5">
                    <div class="floating-animation mb-4">
                        <i class="bi bi-exclamation-triangle" style="font-size: 5rem; color: var(--accent);"></i>
                    </div>
                    <h2 class="gradient-text mb-3">Something Went Wrong</h2>
                    <p class="lead text-muted mb-4"><%= error %></p>
                    <a href="/" class="btn btn-primary btn-lg">
                        <i class="bi bi-house-door me-2"></i>Go Back Home
                    </a>
                </div>
            </div>
        </div>
    <% } else if (locals.blog) { %>
        <div class="main-content">
            <article class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-10">
                        <!-- Breadcrumb -->
                        <nav aria-label="breadcrumb" class="mb-4">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/" class="text-decoration-none" style="color: var(--primary);"><i class="bi bi-house-door me-1"></i>Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Blog Details</li>
                            </ol>
                        </nav>
                        
                        <!-- Blog Title -->
                        <header class="mb-5 text-center">
                            <h1 class="display-4 mb-4" style="line-height: 1.3;"><%= blog.title %></h1>
                            
                            <!-- Author Info -->
                            <div class="d-flex align-items-center justify-content-center gap-3 mb-4">
                                <img src="<%= blog.createdBy.profileImageURL || '/images/avatar.jpg' %>" alt="<%= blog.createdBy.name %>" 
                                     class="rounded-circle" width="60" height="60" style="object-fit: cover; border: 3px solid white; box-shadow: var(--shadow-md);"
                                     onerror="this.src='/images/avatar.jpg';">
                                <div class="text-start">
                                    <h6 class="mb-1 fw-bold"><a href="/user/profile/<%= blog.createdBy._id %>" class="text-decoration-none" style="color: inherit;"><%= blog.createdBy.name %></a></h6>
                                    <small class="text-muted">
                                        <i class="bi bi-calendar3 me-1"></i>
                                        <%= new Date(blog.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                    </small>
                                </div>
                            </div>

                            <% if (locals.user && user._id.toString() === blog.createdBy._id.toString()) { %>
                                <div class="d-flex align-items-center justify-content-center gap-3 flex-wrap">
                                    <div class="alert alert-info d-inline-flex align-items-center mb-0">
                                        <i class="bi bi-info-circle me-2"></i>
                                        <span>You are the author of this blog</span>
                                    </div>
                                    <a href="/blog/edit/<%= blog._id %>" class="btn btn-outline-primary">
                                        <i class="bi bi-pencil-square me-2"></i>Edit Blog
                                    </a>
                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                        <i class="bi bi-trash me-2"></i>Delete Blog
                                    </button>
                                </div>

                                <!-- Delete Confirmation Modal -->
                                <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content" style="border-radius: var(--radius); border: 1px solid var(--border);">
                                            <div class="modal-header border-0 pb-0">
                                                <h5 class="modal-title" id="deleteModalLabel">
                                                    <i class="bi bi-exclamation-triangle text-danger me-2"></i>Delete Blog
                                                </h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <p class="mb-1">Are you sure you want to delete <strong>&quot;<%= blog.title %>&quot;</strong>?</p>
                                                <p class="text-muted small mb-0">This action cannot be undone. All comments on this blog will also be deleted.</p>
                                            </div>
                                            <div class="modal-footer border-0 pt-0">
                                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                                                    <i class="bi bi-x-circle me-1"></i>Cancel
                                                </button>
                                                <form action="/blog/<%= blog._id %>/delete" method="POST" class="d-inline">
                                                    <button type="submit" class="btn btn-danger">
                                                        <i class="bi bi-trash me-1"></i>Yes, Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                        </header>

                        <!-- Cover Image -->
                        <% if (blog.coverImageURL) { %>
                            <div class="mb-5">
                                <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" 
                                     class="img-fluid rounded-3 shadow-lg" style="width: 100%; max-height: 500px; object-fit: cover;">
                            </div>
                        <% } %>

                        <!-- Blog Content -->
                        <section class="blog-detail-content mb-5 px-lg-4">
                            <%- blog.body.replace(/\n/g, '<br>') %>
                        </section>

                        <hr class="my-5">

                        <!-- Comments Section -->
                        <section class="comments-section mb-5">
                            <h3 class="section-title mb-4">
                                <i class="bi bi-chat-dots me-2"></i>
                                Comments <span class="badge badge-author"><%= locals.comments ? comments.length : 0 %></span>
                            </h3>

                            <!-- Add Comment Form -->
                            <% if (locals.user) { %>
                                <div class="mb-4" style="background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;">
                                    <div class="p-4">
                                        <h5 class="mb-3">
                                            <i class="bi bi-plus-circle me-2"></i>Share Your Thoughts
                                        </h5>
                                        <form action="/blog/comment/<%= blog._id %>" method="POST">
                                            <div class="d-flex gap-3 mb-3">
                                                <img src="<%= user.profileImageURL || '/images/avatar.jpg' %>" alt="<%= user.name %>" 
                                                     class="rounded-circle" width="50" height="50" style="object-fit: cover;"
                                                     onerror="this.src='/images/avatar.jpg';">
                                                <textarea class="form-control" name="content" rows="3" 
                                                        placeholder="What are your thoughts on this story?" 
                                                        maxlength="500" required style="resize: none;"></textarea>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <small class="text-muted">
                                                    <i class="bi bi-person-circle me-1"></i>
                                                    Posting as <strong><%= user.name %></strong>
                                                </small>
                                                <button type="submit" class="btn btn-primary">
                                                    <i class="bi bi-send me-2"></i>Post Comment
                                                </button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            <% } else { %>
                                <div class="alert alert-info d-flex align-items-center">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <div>
                                        <a href="/user/signin" class="alert-link fw-semibold">Sign in</a> to join the conversation and share your thoughts!
                                    </div>
                                </div>
                            <% } %>

                            <!-- Display Comments -->
                            <% if (locals.comments && comments.length > 0) { %>
                                <div class="comments-list">
                                    <% comments.forEach(comment => { %>
                                        <div class="comment-card">
                                            <div class="d-flex gap-3">
                                                <img src="<%= comment.user.profileImageURL || '/images/avatar.jpg' %>" alt="<%= comment.user.name %>" 
                                                     class="rounded-circle" width="50" height="50" style="object-fit: cover;"
                                                     onerror="this.src='/images/avatar.jpg';">
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                        <div>
                                                            <h6 class="mb-0 fw-semibold">
                                                                <%= comment.user.name %>
                                                                <% if (comment.user._id.toString() === blog.createdBy._id.toString()) { %>
                                                                    <span class="badge badge-author ms-2">Author</span>
                                                                <% } %>
                                                            </h6>
                                                        </div>
                                                        <small class="text-muted">
                                                            <i class="bi bi-clock me-1"></i>
                                                            <%= new Date(comment.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                                        </small>
                                                    </div>
                                                    <p class="mb-0" style="white-space: pre-wrap; color: var(--text);"><%= comment.content %></p>
                                                </div>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-5">
                                    <div class="floating-animation mb-3">
                                        <i class="bi bi-chat-dots" style="font-size: 4rem; color: var(--primary-light);"></i>
                                    </div>
                                    <h5 class="text-muted mb-2">No comments yet</h5>
                                    <p class="text-muted">Be the first to share your thoughts on this story!</p>
                                </div>
                            <% } %>
                        </section>

                        <hr class="my-5">

                        <!-- Footer Actions -->
                        <section class="text-center py-4">
                            <h5 class="mb-4">Enjoyed this story?</h5>
                            <div class="d-flex gap-3 justify-content-center flex-wrap">
                                <a href="/" class="btn btn-outline-secondary btn-lg">
                                    <i class="bi bi-arrow-left me-2"></i>More Stories
                                </a>
                                <% if (locals.user) { %>
                                    <a href="/blog/add" class="btn btn-primary btn-lg">
                                        <i class="bi bi-pencil-square me-2"></i>Write Your Own
                                    </a>
                                <% } else { %>
                                    <a href="/user/signup" class="btn btn-primary btn-lg">
                                        <i class="bi bi-rocket-takeoff me-2"></i>Join Blogify
                                    </a>
                                <% } %>
                            </div>
                        </section>
                    </div>
                </div>
            </article>
        </div>
    <% } else { %>
        <div class="main-content">
            <div class="container">
                <div class="text-center py-5">
                    <div class="floating-animation mb-4">
                        <i class="bi bi-file-earmark-x" style="font-size: 5rem; color: var(--primary-light);"></i>
                    </div>
                    <h2 class="gradient-text mb-3">Blog Not Found</h2>
                    <p class="lead text-muted mb-4">The story you're looking for doesn't exist or has been removed.</p>
                    <a href="/" class="btn btn-primary btn-lg">
                        <i class="bi bi-house-door me-2"></i>Discover Other Stories
                    </a>
                </div>
            </div>
        </div>
    <% } %>

    <%- include('./partials/scripts.ejs') %>
</body>
</html>
