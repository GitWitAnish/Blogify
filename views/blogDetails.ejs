<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head.ejs') %>
    <title><% if (locals.blog) { %><%= blog.title %> - Blog<% } else { %>Blog Details<% } %></title>
</head>
<body>
    <%- include('./partials/nav.ejs') %>
    
    <div class="container mt-4">
        <% if (locals.error) { %>
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">Error!</h4>
                <p><%= error %></p>
                <hr>
                <p class="mb-0">
                    <a href="/" class="btn btn-primary">Go Back to Home</a>
                </p>
            </div>
        <% } else if (locals.blog) { %>
            <div class="row">
                <div class="col-12">
                    <!-- Blog Header -->
                    <div class="mb-4">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Blog Details</li>
                            </ol>
                        </nav>
                        
                        <h1 class="display-4 mb-3"><%= blog.title %></h1>
                        
                        <!-- Author Info -->
                        <div class="d-flex align-items-center mb-3">
                            <img src="/images/avatar.jpg" alt="<%= blog.createdBy.name %>" 
                                 class="rounded-circle me-3" width="50" height="50" style="object-fit: cover;">
                            <div>
                                <h6 class="mb-0">By <%= blog.createdBy.name %></h6>
                                <small class="text-muted">
                                    Published on <%= new Date(blog.createdAt).toLocaleDateString('en-US', { 
                                        year: 'numeric', 
                                        month: 'long', 
                                        day: 'numeric' 
                                    }) %>
                                    <% if (blog.updatedAt && blog.updatedAt.getTime() !== blog.createdAt.getTime()) { %>
                                        • Updated on <%= new Date(blog.updatedAt).toLocaleDateString('en-US', { 
                                            year: 'numeric', 
                                            month: 'long', 
                                            day: 'numeric' 
                                        }) %>
                                    <% } %>
                                </small>
                            </div>
                        </div>

                        <!-- Edit/Delete Actions for Author -->
                        <% if (locals.user && user._id.toString() === blog.createdBy._id.toString()) { %>
                            <div class="mb-3">
                                <div class="alert alert-info">
                                    <small><i class="bi bi-info-circle"></i> You are the author of this blog post</small>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <!-- Cover Image -->
                    <% if (blog.coverImageURL) { %>
                        <div class="mb-4">
                            <img src="<%= blog.coverImageURL %>" alt="<%= blog.title %>" 
                                 class="img-fluid rounded shadow" style="width: 100%; max-height: 400px; object-fit: cover;">
                        </div>
                    <% } %>

                    <!-- Blog Content -->
                    <div class="mb-5">
                        <div class="blog-content" style="font-size: 1.1rem; line-height: 1.7;">
                            <%- blog.body.replace(/\n/g, '<br>') %>
                        </div>
                    </div>

                    <!-- Comments Section -->
                    <div class="mb-5">
                        <hr>
                        <h3 class="mb-4">
                            <i class="bi bi-chat-dots"></i> 
                            Comments (<%= locals.comments ? comments.length : 0 %>)
                        </h3>

                        <!-- Add Comment Form -->
                        <% if (locals.user) { %>
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">
                                        <i class="bi bi-plus-circle"></i> Add a Comment
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <form action="/blog/comment/<%= blog._id %>" method="POST">
                                        <div class="mb-3">
                                            <div class="d-flex align-items-start">
                                                <img src="/images/avatar.jpg" alt="<%= user.name %>" 
                                                     class="rounded-circle me-3" width="40" height="40" style="object-fit: cover;">
                                                <div class="flex-grow-1">
                                                    <textarea class="form-control" name="content" rows="3" 
                                                            placeholder="Share your thoughts..." 
                                                            maxlength="500" required></textarea>
                                                    <div class="form-text">Maximum 500 characters</div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="text-muted">
                                                Commenting as <strong><%= user.name %></strong>
                                            </small>
                                            <button type="submit" class="btn btn-primary">
                                                <i class="bi bi-send"></i> Post Comment
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> 
                                <a href="/user/signin" class="alert-link">Sign in</a> to join the conversation and leave a comment.
                            </div>
                        <% } %>

                        <!-- Display Comments -->
                        <% if (locals.comments && comments.length > 0) { %>
                            <div class="comments-list">
                                <% comments.forEach(comment => { %>
                                    <div class="card mb-3">
                                        <div class="card-body">
                                            <div class="d-flex align-items-start">
                                                <img src="/images/avatar.jpg" alt="<%= comment.user.name %>" 
                                                     class="rounded-circle me-3" width="40" height="40" style="object-fit: cover;">
                                                <div class="flex-grow-1">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <h6 class="mb-0">
                                                            <%= comment.user.name %>
                                                            <% if (comment.user._id.toString() === blog.createdBy._id.toString()) { %>
                                                                <span class="badge bg-primary ms-1">Author</span>
                                                            <% } %>
                                                        </h6>
                                                        <small class="text-muted">
                                                            <%= new Date(comment.createdAt).toLocaleString('en-US', { 
                                                                year: 'numeric', 
                                                                month: 'short', 
                                                                day: 'numeric',
                                                                hour: '2-digit',
                                                                minute: '2-digit'
                                                            }) %>
                                                        </small>
                                                    </div>
                                                    <p class="mb-0" style="white-space: pre-wrap;"><%= comment.content %></p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        <% } else { %>
                            <div class="text-center py-4">
                                <i class="bi bi-chat-dots text-muted" style="font-size: 3rem;"></i>
                                <h5 class="text-muted mt-2">No comments yet</h5>
                                <p class="text-muted">Be the first to share your thoughts!</p>
                            </div>
                        <% } %>
                    </div>

                    <!-- Blog Footer -->
                    <hr>
                    <div class="row mt-4">
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-body text-center">
                                    <img src="/images/avatar.jpg" alt="<%= blog.createdBy.name %>" 
                                         class="rounded-circle mb-2" width="80" height="80" style="object-fit: cover;">
                                    <h5 class="card-title"><%= blog.createdBy.name %></h5>
                                    <p class="card-text text-muted">Blog Author</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="d-grid gap-2">
                                <a href="/" class="btn btn-outline-primary">
                                    <i class="bi bi-arrow-left"></i> Back to All Blogs
                                </a>
                                <% if (locals.user) { %>
                                    <a href="/blog/add" class="btn btn-primary">
                                        <i class="bi bi-plus-circle"></i> Write New Blog
                                    </a>
                                <% } else { %>
                                    <a href="/user/signin" class="btn btn-success">
                                        <i class="bi bi-person-plus"></i> Sign In to Write
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <!-- Fallback for no blog data -->
            <div class="text-center py-5">
                <h2 class="text-muted">Blog Not Found</h2>
                <p class="text-muted">The blog post you're looking for doesn't exist or has been removed.</p>
                <a href="/" class="btn btn-primary">Go Back to Home</a>
            </div>
        <% } %>
    </div>

    <%- include('./partials/scripts.ejs') %>
</body>
</html>
